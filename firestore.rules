rules_version = '2';

// Shared Firestore rules for the Librebook Android app and web app.
// Keep this file aligned in both project directories and deploy the same
// ruleset for both clients so behavior stays consistent across platforms.

service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helper functions
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        ('admin' in request.auth.token && request.auth.token.admin == true) ||
        ('email' in request.auth.token && request.auth.token.email == 'smenaria2@gmail.com')
      );
    }

    function uid() {
      return request.auth.uid;
    }

    function ownsExisting(field) {
      return signedIn() && resource.data[field] == uid();
    }

    function ownsIncoming(field) {
      return signedIn() && request.resource.data[field] == uid();
    }

    function ownsIncomingAny(primary, fallback) {
      return signedIn() && (
        request.resource.data[primary] == uid() ||
        request.resource.data[fallback] == uid()
      );
    }

    function onlyChanges(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function isPublicFeedPost() {
      return !('visibility' in resource.data) ||
        resource.data.visibility == 'public' ||
        resource.data.privacy == 'public';
    }

    function validCounterDelta(field, minDelta, maxDelta) {
      let before = resource.data.get(field, 0);
      let after = request.resource.data.get(field, 0);
      return before is int &&
        after is int &&
        after - before >= minDelta &&
        after - before <= maxDelta;
    }

    function validExistingCounterDelta(field, minDelta, maxDelta) {
      return request.resource.data[field] is int &&
        resource.data[field] is int &&
        request.resource.data[field] - resource.data[field] >= minDelta &&
        request.resource.data[field] - resource.data[field] <= maxDelta;
    }

    function isBookAuthor(bookId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/books/$(bookId)) &&
        canEditBookData(get(/databases/$(database)/documents/books/$(bookId)).data);
    }

    function canEditBookData(data) {
      return signedIn() && (
        data.authorId == uid() ||
        (
          hasAcceptedCollaboration(data) &&
          data.authorIds is list &&
          uid() in data.authorIds
        )
      );
    }

    function hasAcceptedCollaboration(data) {
      return ('collaborationStatus' in data) &&
        data.collaborationStatus == 'accepted';
    }

    function isPrimaryBookAuthorData(data) {
      return signedIn() && data.authorId == uid();
    }

    function validCollaborationInvite(data) {
      return !('collaboratorId' in data) ||
        !('collaborationStatus' in data) ||
        data.collaborationStatus == null ||
        data.collaborationStatus == 'declined' ||
        (
          data.collaborationStatus == 'pending' &&
          data.collaboratorId is string &&
          data.collaboratorId != uid() &&
          data.authorIds is list &&
          data.authorIds.size() == 1 &&
          uid() in data.authorIds &&
          exists(/databases/$(database)/documents/follows/$(uid() + '_' + data.collaboratorId))
        );
    }

    function validCollaborationResponse() {
      return signedIn() &&
        resource.data.collaborationStatus == 'pending' &&
        resource.data.collaboratorId == uid() &&
        request.resource.data.collaboratorId == resource.data.collaboratorId &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'collaborationStatus',
          'collaborationRespondedAt',
          'authorIds',
          'updatedAt'
        ]) &&
        (
          request.resource.data.collaborationStatus == 'declined' ||
          (
            request.resource.data.collaborationStatus == 'accepted' &&
            request.resource.data.authorIds is list &&
            resource.data.authorId in request.resource.data.authorIds &&
            resource.data.collaboratorId in request.resource.data.authorIds
          )
        );
    }

    function validCollaborationRemoval() {
      return signedIn() &&
        resource.data.collaborationStatus in ['pending', 'accepted'] &&
        (
          resource.data.authorId == uid() ||
          (
            hasAcceptedCollaboration(resource.data) &&
            resource.data.collaboratorId == uid()
          )
        ) &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.authorIds is list &&
        request.resource.data.authorIds.size() == 1 &&
        resource.data.authorId in request.resource.data.authorIds &&
        request.resource.data.authors is list &&
        request.resource.data.authors.size() == 1 &&
        request.resource.data.collaborationStatus == null &&
        request.resource.data.collaboratorId == null &&
        request.resource.data.collaboratorName == null &&
        request.resource.data.collaboratorPhotoURL == null &&
        (
          !hasAcceptedCollaboration(resource.data) ||
          (
            request.resource.data.collaborationRemovedBy == uid() &&
            request.resource.data.collaborationRemovedAt is int &&
            request.resource.data.removedCollaboratorId == resource.data.collaboratorId
          )
        );
    }

    function validPrimaryBookUpdate() {
      return signedIn() &&
        isPrimaryBookAuthorData(resource.data) &&
        !hasAcceptedCollaboration(resource.data) &&
        request.resource.data.authorId == resource.data.authorId &&
        validCollaborationInvite(request.resource.data);
    }

    function validAcceptedCollaborationEdit() {
      return signedIn() &&
        resource.data.collaborationStatus == 'accepted' &&
        canEditBookData(resource.data) &&
        request.resource.data.status != 'deleted' &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.authors == resource.data.authors &&
        request.resource.data.authorIds == resource.data.authorIds &&
        request.resource.data.collaborationStatus == resource.data.collaborationStatus &&
        request.resource.data.collaboratorId == resource.data.collaboratorId &&
        request.resource.data.collaboratorName == resource.data.collaboratorName &&
        request.resource.data.collaboratorPhotoURL == resource.data.collaboratorPhotoURL;
    }

    function validCommentAudioFields(data) {
      return (!('audioUrl' in data) || data.audioUrl is string) &&
        (!('audioObjectKey' in data) || data.audioObjectKey is string) &&
        (!('audioDurationMs' in data) || data.audioDurationMs is int) &&
        (!('audioMimeType' in data) || data.audioMimeType is string) &&
        (!('audioSizeBytes' in data) || data.audioSizeBytes is int);
    }

    function allowsLegacyEmbeddedFeedCommentMutation() {
      return signedIn() &&
        request.resource.data.comments is list &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'comments',
          'commentCount',
          'updatedAt'
        ]) &&
        (
          !('commentCount' in request.resource.data) ||
          !('commentCount' in resource.data) ||
          validCounterDelta('commentCount', -1, 1)
        );
    }

    function validSelfUserUpdate(userId) {
      return signedIn() &&
        userId == uid() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'username',
          'displayName',
          'photoURL',
          'coverPhotoURL',
          'bio',
          'penName',
          'privacyLevel',
          'profileVisibility',
          'pinnedWorks',
          'savedBooks',
          'readingHistory',
          'bookmarks',
          'preferredLanguage',
          'notificationSettings',
          'lastLogin',
          'lastPlatform'
        ]) &&
        request.resource.data.get('id', null) == resource.data.get('id', null) &&
        request.resource.data.get('email', null) == resource.data.get('email', null) &&
        request.resource.data.get('isDeactivated', null) == resource.data.get('isDeactivated', null) &&
        request.resource.data.get('totalPoints', null) == resource.data.get('totalPoints', null) &&
        request.resource.data.get('tier', null) == resource.data.get('tier', null);
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if signedIn() && userId == uid();
      allow update: if signedIn() && (
        validSelfUserUpdate(userId) ||
        isAdmin() ||
        (
          onlyChanges(['followersCount']) &&
          validExistingCounterDelta('followersCount', -1, 1)
        ) ||
        (
          onlyChanges(['followingCount']) &&
          validExistingCounterDelta('followingCount', -1, 1)
        )
      );
      allow delete: if signedIn() && (userId == uid() || isAdmin());
    }

    // Follows collection
    match /follows/{followId} {
      allow read: if true;
      allow create: if ownsIncoming('followerId') &&
        request.resource.data.followingId is string &&
        request.resource.data.followingId != uid();
      allow update: if false;
      allow delete: if ownsExisting('followerId') || isAdmin();
    }

    // Social feed posts
    match /feed/{postId} {
      allow read: if isPublicFeedPost() || ownsExisting('userId') || isAdmin();
      allow create: if ownsIncoming('userId');
      allow update: if signedIn() && (
        ownsExisting('userId') ||
        isAdmin() ||
        (
          onlyChanges(['bookId', 'bookTitle', 'chapterId', 'chapterTitle']) &&
          isBookAuthor(resource.data.bookId) &&
          isBookAuthor(request.resource.data.bookId)
        ) ||
        (
          onlyChanges(['likes']) &&
          request.resource.data.likes is list
        ) ||
        (
          onlyChanges(['likes', 'likesCount']) &&
          request.resource.data.likes is list &&
          validCounterDelta('likesCount', -1, 1)
        ) ||
        (
          onlyChanges(['commentCount']) &&
          validCounterDelta('commentCount', -1, 1)
        ) ||
        allowsLegacyEmbeddedFeedCommentMutation()
      );
      allow delete: if ownsExisting('userId') || isAdmin();
    }

    // Comments for books or feed posts
    match /comments/{commentId} {
      allow read: if true;
      allow create: if ownsIncoming('userId') &&
        validCommentAudioFields(request.resource.data) &&
        (
          request.resource.data.bookId is string ||
          request.resource.data.feedPostId is string
        );
      allow update: if signedIn() && (
        (ownsExisting('userId') && validCommentAudioFields(request.resource.data)) ||
        isAdmin() ||
        (
          onlyChanges(['bookId', 'bookTitle', 'chapterId', 'chapterTitle', 'chapterIndex']) &&
          isBookAuthor(resource.data.bookId) &&
          isBookAuthor(request.resource.data.bookId)
        ) ||
        (
          onlyChanges(['likes']) &&
          request.resource.data.likes is list
        ) ||
        (
          onlyChanges(['likes', 'likesCount']) &&
          request.resource.data.likes is list &&
          validCounterDelta('likesCount', -1, 1)
        ) ||
        (
          onlyChanges(['replies']) &&
          request.resource.data.replies is list
        ) ||
        (
          onlyChanges(['replies', 'repliesCount']) &&
          request.resource.data.replies is list &&
          validCounterDelta('repliesCount', -1, 1)
        ) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isHighlighted',
            'highlightedAt',
            'highlightedByUserId'
          ]) &&
          request.resource.data.bookId is string &&
          request.resource.data.highlightedByUserId == uid() &&
          isBookAuthor(request.resource.data.bookId)
        )
      );
      allow delete: if ownsExisting('userId') || isAdmin();
    }

    // Books and their sub-collections
    match /books/{bookId} {
      allow read: if true;
      allow create: if ownsIncomingAny('authorId', 'userId') &&
        validCollaborationInvite(request.resource.data) ||
        isAdmin();
      allow update: if isAdmin() ||
        validPrimaryBookUpdate() ||
        validAcceptedCollaborationEdit() ||
        validCollaborationResponse() ||
        validCollaborationRemoval() ||
        (
          onlyChanges(['viewCount']) &&
          validCounterDelta('viewCount', 0, 1)
        );
      allow delete: if isPrimaryBookAuthorData(resource.data) &&
        resource.data.collaborationStatus != 'accepted' &&
        !hasAcceptedCollaboration(resource.data) ||
        isAdmin();

      // Sub-collection for tracking unique views
      match /views/{viewerKey} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasOnly(['viewerKey', 'createdAt']) || 
                         request.resource.data.keys().hasOnly(['timestamp', 'viewerId', 'isGuest', 'bookId']) ||
                         (
                           request.resource.data.keys().hasOnly([
                             'viewerKey',
                             'chapterKey',
                             'chapterIndex',
                             'chapterId',
                             'createdAt'
                           ]) &&
                           request.resource.data.viewerKey is string &&
                           request.resource.data.chapterKey is string &&
                           request.resource.data.chapterIndex is int &&
                           (
                             !request.resource.data.keys().hasAny(['chapterId']) ||
                             request.resource.data.chapterId is string
                           )
                         );
      }

      // Sub-collection for book chapters
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if isAdmin() ||
          (
            signedIn() &&
            canEditBookData(get(/databases/$(database)/documents/books/$(bookId)).data)
          );
      }
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == uid());
      // Allow creation only if actor is the signed-in user and payload is valid
      allow create: if signedIn() &&
        (
          isAdmin() ||
          request.resource.data.actorId == uid()
        ) &&
        request.resource.data.userId != uid() && // Prevent self-notifications
        request.resource.data.type in [
          'follow', 'follower', 'post_like', 'feed_comment', 'feed_reply',
          'book_comment', 'book_review', 'book_reply', 'like', 'comment', 'reply',
          'message', 'collaboration_request', 'collaboration_accepted',
          'collaboration_removed', 'mention', 'published', 'chapter_update',
          'feedPost', 'new_creation', 'testimonial', 'groupMessage'
        ];
      allow update: if signedIn() &&
        (isAdmin() || resource.data.userId == uid()) &&
        onlyChanges(['isRead']);
      allow delete: if isAdmin() || (signedIn() && resource.data.userId == uid());
    }

    // Reports for abuse/errors
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn() && (
        request.resource.data.reporterId == uid() ||
        request.resource.data.userId == uid()
      );
      allow update, delete: if isAdmin();
    }

    // User bookmarks/library
    match /bookmarks/{bookmarkId} {
      allow read: if ownsExisting('userId') || isAdmin();
      allow create: if ownsIncoming('userId') || isAdmin();
      allow update, delete: if ownsExisting('userId') || isAdmin();
    }

    // Private Messaging
    match /conversations/{conversationId} {
      allow read: if isAdmin() || (signedIn() && uid() in resource.data.participants);
      allow create: if isAdmin() || (signedIn() && uid() in request.resource.data.participants);
      allow update: if signedIn() &&
        (
          isAdmin() ||
          (
            uid() in resource.data.participants &&
            uid() in request.resource.data.participants
          )
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() ||
          (
            signedIn() &&
            uid() in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          );
        allow create: if isAdmin() ||
          (
            ownsIncoming('senderId') &&
            uid() in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          );
        allow update: if isAdmin() ||
          (
            signedIn() &&
            uid() in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
            onlyChanges(['deletedFor']) &&
            request.resource.data.deletedFor is list &&
            request.resource.data.deletedFor.hasAll(resource.data.get('deletedFor', [])) &&
            uid() in request.resource.data.deletedFor
          );
        allow delete: if isAdmin() ||
          (
            ownsExisting('senderId') &&
            uid() in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          );
      }
    }

    // Global settings
    match /settings/{settingId} {
      allow read: if settingId != 'keys';
      allow write: if isAdmin();
    }

    match /settings/keys {
      allow read, write: if isAdmin();
    }

    // Home banners
    match /home-banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Daily topics
    match /daily-topics/{topicId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Book recommendations / Archive votes
    match /recommendations/{recommendationId} {
      allow read: if true;
      allow create, update: if signedIn() &&
        request.resource.data.userId == uid() &&
        recommendationId == uid() + '_' + request.resource.data.bookId &&
        request.resource.data.type in ['up', 'down'];
      allow delete: if (signedIn() && resource.data.userId == uid()) || isAdmin();
    }

    match /book_stats/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // IA Upvotes cache
    match /ia_upvotes/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gamification history
    match /points_history/{historyId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // NO CATCH-ALL READ. Access must be explicit per collection.
  }
}
